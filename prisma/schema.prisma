generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum WidgetStatus {
  active
  inactive
}

model User {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  passwordHash String         @default("changeme")
  createdAt    DateTime       @default(now())
  refreshTokens RefreshToken[]
  widgets      Widget[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Widget {
  id        String       @id @default(uuid())
  type      String
  title     String
  status    WidgetStatus @default(active)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  userId    String?
  user      User?        @relation(fields: [userId], references: [id])
}
